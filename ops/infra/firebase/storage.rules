rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Deny everything by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Org-scoped objects: gs://bucket/{orgId}/{appId}/...
    // Custom claims must include org_id and app_access map.
    match /{orgId}/{appId}/{allPaths=**} {
      allow read: if request.auth != null
        && request.auth.token.org_id == orgId;

      allow write: if request.auth != null
        && request.auth.token.org_id == orgId
        && request.auth.token.app_access[appId] == true;
    }
  }
}
